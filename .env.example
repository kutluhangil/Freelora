# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Lemon Squeezy
NEXT_PUBLIC_LEMON_SQUEEZY_STORE_ID=123456
LEMON_SQUEEZY_API_KEY=your-api-key
LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# Lemon Squeezy plan variant IDs
NEXT_PUBLIC_LS_BASIC_MONTHLY=111111
NEXT_PUBLIC_LS_BASIC_YEARLY=222222
NEXT_PUBLIC_LS_PRO_MONTHLY=333333
NEXT_PUBLIC_LS_PRO_YEARLY=444444

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=Freelora <noreply@yourdomain.com>

# Exchange rates (exchangerate-api.com)
EXCHANGE_RATE_API_KEY=your-api-key

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Cron security (for /api/cron/* routes)
CRON_SECRET=your-random-secret-here

# Docker / SSL (used in docker-compose)
DOMAIN=yourdomain.com
SSL_EMAIL=you@yourdomain.com
